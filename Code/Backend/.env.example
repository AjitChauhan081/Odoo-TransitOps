# ─── TransitOps Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — NEVER commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:1234@localhost:5433/TransitOps

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Secret key used to sign JWT tokens — change this to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_secret_key

# JWT algorithm (HS256 is standard)
ALGORITHM=HS256

# Token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Server ───────────────────────────────────────────────────────────────────
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
